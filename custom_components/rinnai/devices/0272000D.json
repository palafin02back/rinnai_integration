{
    "_comment": "RUS-R**E51系列 热水器",
    "name": "Rinnai Hot Water Heater E51",
    "features": {
        "heat_type": "E51_HOT_WATER",
        "energy_data_keys": [
            "gasConsumption"
        ]
    },
    "supported_requests": [
        "get_schedule",
        "save_schedule",
        "air_consumption",
        "gas_water_consumption"
    ],
    "schedule_config": {
        "total_length": 34,
        "status_byte_index": 0,
        "mode_byte_index": 1,
        "data_start_byte_index": 2,
        "bytes_per_mode": 3,
        "mode_count": 5
    },
    "processors": {
        "hotWaterTempSetting": [
            "hex4_to_int"
        ],
        "tempSettingUpper": [
            "hex4_to_int"
        ],
        "tempSettinglower": [
            "hex4_to_int"
        ],
        "gasConsumption": [
            "hex_to_int",
            {
                "func": "divide",
                "args": [
                    10000
                ]
            }
        ]
    },
    "state_mapping": {
        "hot_water_temp": "hotWaterTempSetting",
        "temp_setting_upper": "tempSettingUpper",
        "temp_setting_lower": "tempSettinglower",
        "operation_mode": "operationMode",
        "burning_state": "burningState",
        "gas_usage": "gasConsumption",
        "error_type": "errorType",
        "frozen_state": "frozenState",
        "power": "power",
        "eco_mode": "ecoMode",
        "eco_heat_load": "ecoHeatLoad",
        "cycle_mode": "cycleModeSetting",
        "cycle_insulation": "temporaryCycleInsulationSetting",
        "pressurization_mode": "pressurizationMode",
        "fault_code": "faultCode",
        "error_code": "errorCode",
        "byte_str": "byteStr"
    },
    "entities": {
        "water_heater": [
            {
                "name": "热水器",
                "key": "main",
                "min_temp": 35,
                "max_temp": 60,
                "step": 1,
                "command_topic": "hotWaterTempSetting",
                "temp_format": "hex4",
                "state_attribute": "hot_water_temp",
                "min_temp_attribute": "temp_setting_lower",
                "max_temp_attribute": "temp_setting_upper",
                "operation_mode": "Hot Water"
            }
        ],
        "sensor": [
            {
                "key": "hot_water_temp",
                "name": "热水设定温度",
                "device_class": "temperature",
                "state_class": "measurement",
