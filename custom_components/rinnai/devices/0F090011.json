{
  "name": "Rinnai Heat Pump Thermostat",
  "features": {"heat_type": "HP_THERMOSTAT"},
  "supported_requests": [],
  "processors": {
    "heatingTempSetting": ["hex_fraction_to_float"],
    "roomTemperature": ["hex_fraction_to_float"],
    "heatingOutletWaterTemp": ["hex_fraction_to_float"],
    "outdoorTemperature": ["hex_fraction_to_float"],
    "heatingReturnWaterTemp": ["hex_fraction_to_float"]
  },
  "state_mapping": {
    "power": "power",
    "fan_state": "fanState",
    "operation_mode": "operationMode",
    "rapid_heating": "rapidHeating",
    "heating_reservation": "heatingReservationSetting",
    "heating_temp": "heatingTempSetting",
    "room_temperature": "roomTemperature",
    "heating_outlet_water_temp": "heatingOutletWaterTemp",
    "outdoor_temperature": "outdoorTemperature",
    "heating_return_water_temp": "heatingReturnWaterTemp",
    "fault_code": "faultCode",
    "error_code": "errorCode"
  },
  "entities": {
    "sensor": [
      {"key": "room_temperature", "name": "室内温度", "device_class": "temperature", "state_class": "measurement", "unit_of_measurement": "°C", "state_attribute": "room_temperature"},
      {"key": "heating_outlet_water_temp", "name": "采暖出水温度", "device_class": "temperature", "state_class": "measurement", "unit_of_measurement": "°C", "state_attribute": "heating_outlet_water_temp"},
      {"key": "outdoor_temperature", "name": "室外温度", "device_class": "temperature", "state_class": "measurement", "unit_of_measurement": "°C", "state_attribute": "outdoor_temperature"},
      {"key": "heating_return_water_temp", "name": "采暖回水温度", "device_class": "temperature", "state_class": "measurement", "unit_of_measurement": "°C", "state_attribute": "heating_return_water_temp"},
      {"key": "fault_code", "name": "故障码", "entity_category": "diagnostic", "state_attribute": "fault_code"}
    ],
    "switch": [
      {"key": "power", "name": "电源", "type": "command_switch", "command_key": "power", "command_on": "01", "command_off": "00", "state_attribute": "power", "on_values": ["1", "01"]},
      {"key": "rapid_heating", "name": "快速采暖", "type": "command_switch", "command_key": "rapidHeating", "command_on": "01", "command_off": "00", "state_attribute": "rapid_heating", "on_values": ["1", "01"]},
      {"key": "heating_reservation", "name": "采暖预约", "type": "command_switch", "command_key": "heatingReservationSetting", "command_on": "01", "command_off": "00", "state_attribute": "heating_reservation", "on_values": ["1", "01"]}
    ],
    "select": [
      {
        "key": "fan_state", "name": "风速", "type": "command_select", "command_key": "fanState", "state_attribute": "fan_state",
        "options_map": {"自动": "00", "低速": "01", "中速": "02", "高速": "03"}
      },
      {
        "key": "operation_mode", "name": "运行模式", "type": "command_select", "command_key": "operationMode", "state_attribute": "operation_mode",
        "options_map": {"自动": "00", "制热": "01", "制冷": "02", "送风": "03", "除湿": "04"}
      }
    ],
    "number": [
      {
        "key": "heating_temp_setpoint", "name": "采暖温度设定", "command_key": "heatingTempSetting", "state_attribute": "heating_temp",
        "min": 5, "max": 35, "step": 0.5, "unit_of_measurement": "°C", "temp_format": "hex_fraction"
      }
    ]
  }
