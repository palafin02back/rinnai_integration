      {"key": "hp_unit_hot_temp_setpoint", "name": "主机制热温度设定", "command_key": "hpUnitHotTempSetting", "state_attribute": "hp_unit_hot_temp", "min": 20, "max": 60, "step": 1, "unit_of_measurement": "°C", "temp_format": "hex2"}
